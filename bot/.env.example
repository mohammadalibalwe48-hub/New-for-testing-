# Required: get this from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Optional: where to put downloaded files. Defaults to bot/downloads/.
# DOWNLOAD_DIR=bot/downloads

# Optional: Telegram outbound cap (Bot API standard limit is 50 MB).
# MAX_FILE_SIZE_MB=50

# Optional: cap video resolution to keep files under MAX_FILE_SIZE_MB.
# MAX_VIDEO_HEIGHT=720

# Optional: comma-separated list of Telegram user IDs allowed to use the bot.
# Leave empty to allow anyone who messages the bot.
# ALLOWED_USER_IDS=
